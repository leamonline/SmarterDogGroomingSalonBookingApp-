# ──────────────────────────────────────────────────
# Smarter Dog Grooming Salon — Environment Variables
# Copy this file to .env.local and fill in your values.
# NEVER commit .env.local to version control.
# ──────────────────────────────────────────────────

# Required — must be a long, random secret (min 32 chars)
JWT_SECRET=change-me-to-a-long-random-secret

# Server port (default: 3001)
PORT=3001

# CORS origin for the Vite dev server (default: * — lock down in production)
CORS_ORIGIN=http://localhost:3000

# How many SQLite backups to retain in data/backups/ (default: 20)
# MAX_BACKUPS=20

# ──────────────────────────────────────────────────
# Email / SMTP (optional — without these, messages are logged as 'simulated')
# Supports any SMTP provider: Gmail, SendGrid, Mailgun, etc.
# ──────────────────────────────────────────────────
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USER=your-smtp-user
# SMTP_PASS=your-smtp-password
# SMTP_FROM="Smarter Dog Grooming Salon <noreply@smarterdoggrooming.com>"

# ──────────────────────────────────────────────────
# Node environment
# ──────────────────────────────────────────────────
NODE_ENV=development
